layout {

    focus-ring {
        active-color   "#98a4b3"
        inactive-color "#1c1e21"
        urgent-color   "#fd4663"
    }

    border {
        active-color   "#98a4b3"
        inactive-color "#1c1e21"
        urgent-color   "#fd4663"
    }

    shadow {
        color "#1c1e2170"
    }

    tab-indicator {
        active-color   "#98a4b3"
        inactive-color "#414b58"
        urgent-color   "#fd4663"
    }

    insert-hint {
        color "#98a4b380"
    }
}

recent-windows {
    highlight {
        active-color "#98a4b3"
        urgent-color "#fd4663"
    }
}
