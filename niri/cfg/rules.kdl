    window-rule {
        geometry-corner-radius 18
        clip-to-geometry true

    }

    layer-rule {
        match namespace="^noctalia-wallpaper*"
        place-within-backdrop true
    }

window-rule {
    match app-id="^cs2$"     
    open-floating true
}
window-rule {
    match title="Counter-Strike 2"
    open-floating true
}

window-rule {
    match app-id="Nautilus"
    background-effect {
        blur true
        xray false // Disables xray so blur is clearly visible
    }
}
